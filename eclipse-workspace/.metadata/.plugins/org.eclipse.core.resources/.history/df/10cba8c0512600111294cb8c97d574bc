package associacao;
import java.util.Scanner;

public class Leitor {
	
	private String nome;
	private Livro[] livros = new Livro[3];
	
	Leitor(String nome) {
		this.nome = nome;
	}
	
	public void livrosLidos(Scanner sc) {
		for(int i = 0; i < livros.length; i++) {
			Livro l = new Livro();
			l.registrarLivro(sc);
			livros[i] = l;
		}
	}
	
	public void dadosLeitor(Scanner sc) {
		System.out.println("--- Dados Leitor ---");
		System.out.println("Nome: " + nome);
		for (int i = 0; i < livros.length; i++) {
			System.out.println("--- Livro " + i+1 + " ---");
			System.out.println("Titulo: " + livros[i].getTitulo());
			System.out.println("Autor: " + livros[i].getAutor());
		}
	}
	
}
