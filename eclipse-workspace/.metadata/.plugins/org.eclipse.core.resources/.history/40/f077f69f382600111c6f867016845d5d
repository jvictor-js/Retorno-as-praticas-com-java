package questao3;

public class ContaEspecial extends Conta{
	
	ContaEspecial(){}

	ContaEspecial(String nomeTitular, String tipoConta, double saldo){
		super(nomeTitular, tipoConta, saldo);
	}
	
	@Override
	public void sacar(double saque) {
		if (saldo == 0) {
			System.out.println("Impossível sacar! Deposite primeiro.");
		} else if (saque > saldo) {
			saldo += saque;
			saldo -= saque;
			System.out.println("Saldo atual: " + saldo);
		} else if (saque < 0){
			System.out.println("Saque inválido.");
		} else {
			saldo -= saque;
			System.out.println("Saque de " + saque);
			System.out.println("Saldo atual: " + saldo);
		}
	}
	
}
