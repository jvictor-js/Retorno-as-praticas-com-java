package questao2;

public class Automovel extends Veiculo {
	
	public void trocarOleo(float velocidade) {
		if (velocidade > 100) {
			velocidade = 0;
		}
	}
	
	@Override
	public float acelerar(float velocidade) { 
		for (int i = 0; i < velocidade; i++) {
			velocidade++;
		}
		return velocidade;
	}
	
	@Override
	public void parar() {
		System.out.println("Parando automovel...");
	}
	
}
