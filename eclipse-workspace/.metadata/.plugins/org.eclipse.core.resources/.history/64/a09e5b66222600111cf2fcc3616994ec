package questao2;

public class Cliente extends Pessoa{
	
	private int codigo;
	private String apelido;
	
	Cliente(){}
	
	Cliente(String nome, String cpf, int codigo, String apelido){
		super(nome, cpf);
		this.codigo = codigo;
		this.apelido = apelido;
	}
	
	@Override
	public void mostraDados() {
		System.out.println("--- Dados do cliente ---");
		super.mostraDados();
		System.out.println("Código do cliente: " + codigo);
	}
	
	public String mostraDados(String apelido) {
		return apelido;
	}
	
}
